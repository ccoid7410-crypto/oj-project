// Prisma schema for Online Judge backend
// Run `npx prisma generate` and `npx prisma migrate dev` on a machine
// with internet access to prisma binaries (this sandbox blocks that host).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MEMBER // 동아리 부원: 홈페이지 접속 자격
  ADMIN
}

enum Language {
  C
  CPP
  JAVA
  PYTHON3
  JAVASCRIPT
  GO
}

enum SubmissionStatus {
  PENDING
  JUDGING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  RUNTIME_ERROR
  COMPILE_ERROR
  INTERNAL_ERROR
}

/// 굵은 단위의 티어. 실제 세분화된 표시/연산은 Problem.level(1~30)을 기준으로 한다.
enum Difficulty {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
  RUBY
}

enum ProblemStatus {
  DRAFT           // 작성 중 (작성자만 봄)
  PENDING_REVIEW  // 어드민 승인 대기(제안됨)
  PUBLISHED       // 공개됨
  REJECTED        // 반려됨
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  username     String       @unique
  passwordHash String
  name         String? // 실명. 가입 시 필수 입력, 없는 기존 계정은 로그인 후 등록을 강제한다(Layout 참고)
  preferredLanguage Language? // 기본 제출 언어. 문제 페이지에서 자동 선택된다
  role         Role         @default(USER)
  customTitle  String?      @db.VarChar(20) // 관리자가 지정하는 닉네임 앞 공개 칭호
  rating       Int          @default(0) // 상위 100문제(AC) 레이팅 합. RatingService가 재계산한다.
  banned       Boolean      @default(false)
  bannedReason String?
  bannedAt     DateTime?
  studentId    String?      @unique // 학번. 가입 시 자유 입력, 이후 수정은 관리자가 연 기간에만 가능. (NULL은 여러 개 허용, 값이 있으면 유일해야 함)
  bio          String? // 프로필 자기소개 (공개, 마크다운/TeX 지원)
  websites     String[] @default([]) // 프로필에 표시할 개인 사이트 URL 목록 (공개, http/https만 허용, 최대 5개)
  theme        String   @default("system") // UI 테마 설정: system | light | dark (계정 귀속)
  avatar          Bytes?    // 프로필 이미지 원본 바이트. 클라이언트에서 축소해 올리므로 작다(수십 KB). NULL이면 기본(회색) 아바타.
  avatarMime      String?   // avatar의 Content-Type (image/png 등)
  avatarUpdatedAt DateTime? // 아바타 캐시 무효화용(이미지 URL의 ?v= 값)
  banner          Bytes?    // 프로필 배너 이미지 (아바타와 동일 패턴, 폭 1600px로 축소 업로드)
  bannerMime      String?
  bannerUpdatedAt DateTime?
  emailVerified Boolean     @default(false) // 이메일 인증 전에는 로그인 불가(auth.service 참고)
  mustChangePassword Boolean @default(false) // 어드민이 대량 생성한 계정은 최초 로그인 후 비밀번호 변경을 강제한다
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  groupId      String?
  group        Group?       @relation(fields: [groupId], references: [id])

  problems             Problem[]                 @relation("ProblemAuthor")
  reviewedProblems     Problem[]                 @relation("ProblemReviewer")
  submissions          Submission[]
  apiKeys              ApiKey[]                  @relation("ApiKeyCreator")
  contests             Contest[]                 @relation("ContestCreator")
  contestEntries       ContestParticipant[]      @relation("ContestParticipation")
  difficultyVotes      ProblemDifficultyVote[]
  triggeredAlerts      AdminNotification[]       @relation("NotificationVoter")
  emailVerifications   EmailVerificationToken[]
  comments             ProblemComment[]
  classesCreated       ClassRoom[]               @relation("ClassCreator")
  classMemberships     ClassMembership[]
  classNotices         ClassNotice[]             @relation("ClassNoticeAuthor")

  @@map("users")
}

/// 통계/랭킹 필터링용 가벼운 사용자 묶음(수업과 달리 전용 문제/공지/랭킹 화면은 없음).
model Group {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  members User[]

  @@map("groups")
}

/// 회원가입 시 발급되는 이메일 인증 토큰. 원문은 저장하지 않고 sha256 해시만 보관한다(ApiKey와 동일한 방식).
model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("email_verification_tokens")
}

/// 관리자 알림함. 지금은 "난이도 투표가 기존 난이도와 크게 어긋남" 이벤트만 쌓인다.
model AdminNotification {
  id        String   @id @default(uuid())
  type      String // 예: 'DIFFICULTY_VOTE_SPIKE'
  message   String
  problemId String?
  problem   Problem? @relation(fields: [problemId], references: [id], onDelete: Cascade)
  voterId   String?
  voter     User?    @relation("NotificationVoter", fields: [voterId], references: [id])
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("admin_notifications")
}

model Problem {
  id           String      @id @default(uuid())
  displayId    Int         @unique @default(autoincrement()) // BOJ처럼 보이는 고정 문제 번호(1000번대부터)
  title        String
  slug         String      @unique
  description  String
  difficulty   Difficulty  @default(BRONZE) // level로부터 파생되는 굵은 티어(하위호환/필터용)
  level        Int         @default(1) // 1(브론즈 V) ~ 30(루비 I). 세분화된 난이도의 기준값.
  timeLimitMs  Int         @default(2000)
  memoryLimitMb Int        @default(256)
  isPublished  Boolean     @default(false)
  status       ProblemStatus @default(DRAFT)
  reviewNote   String?
  reviewedById String?
  reviewedBy   User?       @relation("ProblemReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  allowedLanguages Language[] @default([]) // 비어있으면 전체 허용
  tags         String[]    @default([])
  authorId     String
  author       User        @relation("ProblemAuthor", fields: [authorId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // 대회 전용 문제: true면 그 문제가 달린 대회가 끝나고 problemsVisibleAfterEnd가 켜진
  // 대회가 하나라도 있기 전까지는 공개 문제 목록/상세에 노출되지 않는다(대회 참가자에게는 그대로 보임).
  contestOnly  Boolean     @default(false)

  testCases       TestCase[]
  submissions     Submission[]
  contestProblems ContestProblem[]
  difficultyVotes ProblemDifficultyVote[]
  notifications   AdminNotification[]
  comments        ProblemComment[]
  classProblems   ClassProblem[]

  @@map("problems")
}

/// 문제 상세페이지의 질문/답변 게시판. 대댓글은 parentId로 표현한다.
model ProblemComment {
  id        String   @id @default(uuid())
  problemId String
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  parentId  String?
  parent    ProblemComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   ProblemComment[] @relation("CommentReplies")
  createdAt DateTime @default(now())

  @@map("problem_comments")
}

/// 문제를 실제로 푼(ACCEPTED) 사용자만 남길 수 있는 체감 난이도 투표. 유저당 문제당 1표.
model ProblemDifficultyVote {
  problemId String
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  level     Int // 1~30
  createdAt DateTime @default(now())

  @@id([problemId, userId])
  @@map("problem_difficulty_votes")
}

model TestCase {
  id         String   @id @default(uuid())
  problemId  String
  problem    Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  input      String
  output     String
  isSample   Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  results    SubmissionTestResult[]

  @@map("test_cases")
}

model Submission {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  problemId   String
  problem     Problem           @relation(fields: [problemId], references: [id])
  contestId   String?
  contest     Contest?          @relation(fields: [contestId], references: [id])
  language    Language
  sourceCode  String
  status      SubmissionStatus  @default(PENDING)
  runtimeMs   Int?
  memoryKb    Int?
  errorMessage String?
  createdAt   DateTime          @default(now())
  judgedAt    DateTime?

  testResults SubmissionTestResult[]

  @@index([userId])
  @@index([problemId])
  @@index([contestId])
  @@map("submissions")
}

model SubmissionTestResult {
  id            String            @id @default(uuid())
  submissionId  String
  submission    Submission        @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  testCaseId    String
  testCase      TestCase          @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  status        SubmissionStatus
  runtimeMs     Int?
  memoryKb      Int?
  output        String?

  @@map("submission_test_results")
}

/// 외부 서비스가 계정 데이터를 조회할 때 쓰는 API 키. 원문 키는 저장하지 않고 sha256 해시만 보관한다.
model ApiKey {
  id          String    @id @default(uuid())
  name        String
  keyHash     String    @unique
  prefix      String    // 표시용 앞 8자리 (ojk_xxxx)
  scopes      String[]  @default(["users:read"])
  createdById String
  createdBy   User      @relation("ApiKeyCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  revoked     Boolean   @default(false)

  @@map("api_keys")
}

/// 채점기 컴파일 옵션/방식을 UI에서 수정할 수 있도록 저장하는 단일 행 설정.
/// config 예: { "CPP": { "compileArgs": ["-O2","-std=c++17","-fno-if-conversion"] }, ... }
model JudgeConfig {
  id        Int      @id @default(1)
  config    Json
  updatedById String?
  updatedAt DateTime @updatedAt

  @@map("judge_config")
}

/// 관리자 페이지에서 수정하는 메일 발송 설정. smtpPass는 앱 비밀번호처럼
/// 발송 시 원문이 필요한 값이라 해시하지 않는다. API 응답에는 절대 포함하지 않는다.
model MailConfig {
  id          Int      @id @default(1)
  enabled     Boolean  @default(false)
  provider    String   @default("gmail")
  from        String
  smtpUser    String
  smtpPass    String
  smtpHost    String?  @default("smtp.gmail.com")
  smtpPort    Int      @default(587)
  smtpSecure  Boolean  @default(false)
  updatedById String?
  updatedAt   DateTime @updatedAt

  @@map("mail_config")
}

/// 동아리 홈페이지 상단에 노출하는 이미지 배너(단일 행 설정). 이미지 파일 자체는 디스크에
/// 저장하고(멀터 업로드) DB에는 상대 경로만 남긴다 - MailConfig의 smtpPass와 달리 비밀값이
/// 아니라 그냥 정적 자산이라 API 응답에 그대로 내려줘도 된다.
model SiteBanner {
  id          Int      @id @default(1)
  enabled     Boolean  @default(false)
  imagePath   String? // uploads/ 기준 상대 경로. null이면 업로드된 이미지가 없다.
  linkUrl     String? // 배너 클릭 시 이동할 주소(선택). 없으면 클릭 불가.
  updatedById String?
  updatedAt   DateTime @updatedAt

  @@map("site_banner")
}

model Contest {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String   @default("")
  startsAt    DateTime
  endsAt      DateTime
  createdById String
  createdBy   User     @relation("ContestCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  // 대회 전용(contestOnly) 문제가 대회 종료 후 일반 문제 목록에 공개될지 여부.
  // false면 대회가 끝나도 계속 비공개로 남는다(문제은행 재사용 목적).
  problemsVisibleAfterEnd Boolean @default(true)

  problems     ContestProblem[]
  participants ContestParticipant[]
  submissions  Submission[]

  @@map("contests")
}

model ContestProblem {
  contestId String
  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  label     String  @default("A") // 대회 내 문제 표기 (A, B, C...)
  order     Int     @default(0)
  points    Int     @default(100)

  @@id([contestId, problemId])
  @@map("contest_problems")
}

model ContestParticipant {
  contestId    String
  contest      Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation("ContestParticipation", fields: [userId], references: [id])
  registeredAt DateTime @default(now())

  @@id([contestId, userId])
  @@map("contest_participants")
}

/// 학번 "수정"이 허용되는 기간(단일 행 설정). 최초 가입 시 입력은 이 기간과 무관하게 항상 가능하다.
model StudentIdEditWindow {
  id          Int       @id @default(1)
  startsAt    DateTime?
  endsAt      DateTime?
  updatedById String?
  updatedAt   DateTime  @updatedAt

  @@map("student_id_edit_window")
}

/// 채점 큐 우선순위 배분용 단일 행 상태(Stride Scheduling).
/// 동아리 학번 명단에 있는 사용자의 제출은 clubPass, 그 외는 generalPass를 각각
/// stride(2 / 3)만큼 증가시키며 그 "이전" 값을 BullMQ job priority로 쓴다.
/// pass가 작을수록 먼저 처리되므로, 이 값들이 자라는 속도 비율(stride의 역수, 6:4)만큼
/// 장기적으로 동아리:일반 제출이 10개 중 6:4 비율로 섞여서 채점된다.
model QueuePassState {
  id         Int      @id @default(1)
  clubPass   Int      @default(0)
  generalPass Int     @default(0)
  updatedAt  DateTime @updatedAt

  @@map("queue_pass_state")
}

/// 문제에 붙일 수 있는 태그 목록(관리자가 추가/삭제). 문제의 tags 배열과는 이름 문자열로 연결된다.
model TagOption {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("tag_options")
}

/// "수업" — 어드민이 만들고 학생을 등록해서 전용 문제집/공지/랭킹을 운영하는 단위.
/// 통계 필터링만 하는 가벼운 Group과 달리 자체 콘텐츠(문제/공지)를 가진다.
model ClassRoom {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String   @default("")
  createdById String
  createdBy   User     @relation("ClassCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  members  ClassMembership[]
  problems ClassProblem[]
  notices  ClassNotice[]

  @@map("classrooms")
}

model ClassMembership {
  classId  String
  class    ClassRoom @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId   String
  user     User      @relation(fields: [userId], references: [id])
  joinedAt DateTime  @default(now())

  @@id([classId, userId])
  @@map("class_memberships")
}

/// 수업 전용 문제집 구성(대회의 ContestProblem과 같은 역할, 배점 없이 순서만).
model ClassProblem {
  classId   String
  class     ClassRoom @relation(fields: [classId], references: [id], onDelete: Cascade)
  problemId String
  problem   Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)
  order     Int       @default(0)

  @@id([classId, problemId])
  @@map("class_problems")
}

model ClassNotice {
  id          String    @id @default(uuid())
  classId     String
  class       ClassRoom @relation(fields: [classId], references: [id], onDelete: Cascade)
  title       String
  content     String
  createdById String
  createdBy   User      @relation("ClassNoticeAuthor", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())

  @@map("class_notices")
}
