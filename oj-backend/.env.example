# Database
DATABASE_URL="postgresql://oj_user:oj_password@localhost:5432/oj_db?schema=public"
# docker-compose가 postgres 컨테이너/DATABASE_URL 조립에 쓰는 값. 운영에서는 반드시 실제 비밀번호로 교체할 것.
POSTGRES_USER="oj_user"
POSTGRES_PASSWORD="oj_password"
POSTGRES_DB="oj_db"

# JWT
# setup.sh가 무작위 값으로 채워준다. 절대 이 예시 값을 그대로 쓰지 말 것.
JWT_SECRET="changeme-run-setup-sh"
JWT_EXPIRES_IN="1d"

# Redis (BullMQ)
REDIS_HOST="localhost"
REDIS_PORT=6379

# App
PORT=3000
# 콤마로 구분된 허용 origin 목록. 운영에서는 실제 프론트엔드 배포 도메인으로 좁혀야 한다.
CORS_ORIGIN="http://localhost:5173"
# 회원가입을 받을 이메일 도메인. 이 도메인이 아니면 가입이 거부된다.
SIGNUP_EMAIL_DOMAIN="cbsh.hs.kr"
# 인증 메일 링크를 만들 때 쓰는 프론트엔드 주소.
FRONTEND_URL="https://oj.jikun.uk"
# 메인 관리자 username. 이 계정은 다른 관리자를 포함해 누구도 관리자 권한을
# 해제할 수 없다. 비워두면 코드의 기본값(users.service.ts)이 사용된다.
ROOT_ADMIN_USERNAME=""

# 메일 발송(SMTP). 비워두면 실제 발송 대신 서버 로그에 인증 링크를 남긴다(로컬 개발용).
# Gmail을 쓰려면 Google 계정에서 2단계 인증을 켠 뒤 "앱 비밀번호" 16자리를 만들어 SMTP_PASS에 넣는다.
# MAIL_PROVIDER="gmail"이면 SMTP_HOST/SMTP_PORT는 자동으로 smtp.gmail.com:587이 된다.
MAIL_PROVIDER=""
MAIL_FROM="no-reply@durunuri-oj.local"
# MAIL_PROVIDER="gmail"
# MAIL_FROM="your-account@gmail.com"
# SMTP_USER="your-account@gmail.com"
# SMTP_PASS="xxxx xxxx xxxx xxxx"
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_SECURE=false

# Judge
JUDGE_DOCKER_SOCK="/var/run/docker.sock"
JUDGE_DEFAULT_TIME_LIMIT_MS=2000
JUDGE_DEFAULT_MEMORY_LIMIT_MB=256
# 동시 채점 개수(JUDGE_CONCURRENCY)는 docker-compose 변수라서 여기가 아니라
# 프로젝트 루트의 .env에 넣어야 한다 (루트 .env.example 참고).

# judge-worker는 docker.sock을 통해 "형제" 컨테이너를 띄우는 구조(Docker-outside-of-Docker)라서,
# 컨테이너 내부에서 만든 임시 디렉토리 경로를 그대로 바인드 마운트 소스로 쓰면 호스트에 해당 경로가 없어 실패한다.
# 그래서 judge-worker 컨테이너와 호스트가 동일한 디렉토리를 공유하도록 볼륨을 고정하고,
# 컨테이너 쪽 마운트 지점(JUDGE_TMP_DIR)과 호스트 쪽 실제 경로(HOST_JUDGE_TMP_DIR)를 각각 알려준다.
# 이 값은 머신마다 다르므로 손으로 채우지 말고 프로젝트 루트의 ./setup.sh를 실행해서 채울 것.
JUDGE_TMP_DIR="/judge-tmp"
HOST_JUDGE_TMP_DIR="run-setup-sh-to-fill-this"
