# 루트 docker-compose.yml이 참조하는 값들 (docker compose가 이 파일을 자동으로 읽는다).
# 실제 앱 런타임 설정(JWT_SECRET 등)은 online-judge/oj-backend/.env 쪽이며, 이 파일과는 별개다.
# 손으로 채우지 말고 ./setup.sh를 실행하면 자동으로 만들어지고 채워진다.

POSTGRES_USER=oj_user
POSTGRES_PASSWORD=oj_password
POSTGRES_DB=oj_db

# 호스트에 노출할 포트. 다른 서비스와 충돌하면 여기서만 바꾸면 된다.
API_PORT=3000
FRONTEND_PORT=8080

# 프론트엔드가 빌드 시점에 박아 넣는 백엔드 API 주소.
# 다른 기기/도메인에 배포한다면 이 값을 그 도메인으로 바꾸고 프론트 이미지를 다시 빌드해야 한다.
VITE_API_URL=http://localhost:3000

# judge-worker 컨테이너와 공유할 호스트 절대경로 (Docker-outside-of-Docker 바인드 마운트용).
# setup.sh가 "$(pwd)/online-judge/oj-backend/judge-tmp"의 절대경로로 자동 채워준다.
HOST_JUDGE_TMP_DIR=run-setup-sh-to-fill-this

# 동시 채점 개수. 라즈베리파이 4B(8GB) 같은 저사양 호스트에서 채점이 자주 밀리거나
# 메모리가 빠듯하면 1로 낮출 것 (기본 2 기준 컴파일 단계에서 순간적으로 ~1GB까지 쓸 수 있음).
JUDGE_CONCURRENCY=2
